@page
@model asp_presentacion.Pages.Ventanas.MisPrestamosModel
@{
    ViewData["Title"] = "Mis Préstamos - BiblioTech";
}

@section Styles {
    <style>
        /* ========== VARIABLES ========== */
        :root {
            --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --primary-500: #667eea;
            --primary-600: #5a67d8;
            --success: #10b981;
            --warning: #f59e0b;
            --error: #ef4444;
            --gray-50: #f9fafb;
            --gray-100: #f3f4f6;
            --gray-200: #e5e7eb;
            --gray-300: #d1d5db;
            --gray-400: #9ca3af;
            --gray-500: #6b7280;
            --gray-600: #4b5563;
            --gray-700: #374151;
            --gray-800: #1f2937;
            --gray-900: #111827;
            --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
            --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1);
            --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1);
            --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1);
            --radius-lg: 1rem;
            --radius-xl: 1.5rem;
            --radius-2xl: 2rem;
            --transition: all 0.3s ease;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            background-attachment: fixed;
            min-height: 100vh;
            padding: 2rem;
        }

        /* ========== CONTENEDOR PRINCIPAL ========== */
        .prestamos-container {
            max-width: 1200px;
            margin: 0 auto;
            animation: fadeInUp 0.5s ease-out;
        }

        @@-webkit-keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .prestamos-card {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(20px);
            border-radius: var(--radius-2xl);
            box-shadow: var(--shadow-xl);
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        /* ========== HEADER ========== */
        .prestamos-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.5rem 2rem;
            background: linear-gradient(135deg, rgba(102, 126, 234, 0.08), rgba(118, 75, 162, 0.04));
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            background: var(--gray-100);
            border-radius: var(--radius-lg);
            text-decoration: none;
            color: var(--gray-700);
            font-weight: 500;
            font-size: 0.875rem;
            transition: var(--transition);
        }

        .btn-back:hover {
            background: var(--gray-200);
            transform: translateX(-2px);
        }

        .title {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-size: 1.5rem;
            font-weight: 700;
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 0;
        }

        .user-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            background: var(--gray-100);
            border-radius: 100px;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--gray-700);
        }

        /* ========== TABS ========== */
        .tabs-container {
            display: flex;
            gap: 0.5rem;
            padding: 1rem 2rem 0 2rem;
            background: white;
            border-bottom: 1px solid var(--gray-200);
        }

        .tab-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.75rem 1.25rem;
            background: transparent;
            border: none;
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--gray-600);
            cursor: pointer;
            transition: var(--transition);
            border-radius: var(--radius-lg) var(--radius-lg) 0 0;
            position: relative;
        }

        .tab-btn:hover {
            color: var(--primary-600);
            background: var(--gray-50);
        }

        .tab-btn.active {
            color: var(--primary-600);
            background: var(--gray-50);
        }

        .tab-btn.active::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            right: 0;
            height: 2px;
            background: var(--primary-gradient);
            border-radius: 2px;
        }

        .tab-count {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 22px;
            height: 22px;
            padding: 0 6px;
            background: var(--gray-200);
            border-radius: 100px;
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--gray-700);
        }

        .tab-btn.active .tab-count {
            background: var(--primary-500);
            color: white;
        }

        /* ========== TAB CONTENT ========== */
        .tab-content {
            display: none;
            padding: 1.5rem 2rem;
            animation: fadeIn 0.3s ease;
        }

        .tab-content.active {
            display: block;
        }

        @@-webkit-keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        @@keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* ========== TABLAS ========== */
        .table-wrapper {
            overflow-x: auto;
            border-radius: var(--radius-lg);
        }

        .prestamos-table, .sanciones-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.875rem;
        }

        .prestamos-table th, .sanciones-table th {
            text-align: left;
            padding: 0.875rem 1rem;
            background: var(--gray-50);
            color: var(--gray-600);
            font-weight: 600;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 1px solid var(--gray-200);
        }

        .prestamos-table td, .sanciones-table td {
            padding: 1rem;
            border-bottom: 1px solid var(--gray-100);
            color: var(--gray-700);
            vertical-align: middle;
        }

        .prestamos-table tr:last-child td, .sanciones-table tr:last-child td {
            border-bottom: none;
        }

        .prestamos-table tr:hover td, .sanciones-table tr:hover td {
            background: var(--gray-50);
        }

        .libro-info {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .libro-info strong {
            color: var(--gray-800);
        }

        .libro-info small {
            font-size: 0.7rem;
            color: var(--gray-400);
        }

        /* ========== ESTADOS ========== */
        .estado-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            padding: 0.25rem 0.75rem;
            border-radius: 100px;
            font-size: 0.7rem;
            font-weight: 700;
        }

        .estado-activo {
            background: linear-gradient(135deg, #d1fae5, #a7f3d0);
            color: #065f46;
        }

        .estado-proximo {
            background: linear-gradient(135deg, #fed7aa, #fdba74);
            color: #92400e;
        }

        .estado-vencido {
            background: linear-gradient(135deg, #fee2e2, #fecaca);
            color: #991b1b;
        }

        .estado-completado {
            background: linear-gradient(135deg, #e0e7ff, #c7d2fe);
            color: #3730a3;
        }

        /* ========== BOTONES ========== */
        .btn-renovar, .btn-detalle {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.375rem 0.875rem;
            border: none;
            border-radius: var(--radius-lg);
            font-size: 0.75rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            margin-right: 0.5rem;
        }

        .btn-renovar {
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
        }

        .btn-renovar:hover {
            transform: translateY(-1px);
            filter: brightness(1.05);
        }

        .btn-detalle {
            background: var(--gray-100);
            color: var(--gray-700);
        }

        .btn-detalle:hover {
            background: var(--gray-200);
            transform: translateY(-1px);
        }

        .text-center {
            text-align: center;
            padding: 2rem;
            color: var(--gray-500);
        }

        /* ========== MODAL ========== */
        .modal-modern {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        .modal-content {
            background: white;
            border-radius: var(--radius-xl);
            max-width: 450px;
            width: 90%;
            animation: fadeInUp 0.3s ease;
            box-shadow: var(--shadow-xl);
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--gray-200);
        }

        .modal-header h3 {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin: 0;
            font-size: 1.125rem;
            color: var(--gray-800);
        }

        .modal-close {
            background: none;
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
            color: var(--gray-400);
            transition: var(--transition);
        }

        .modal-close:hover {
            color: var(--error);
        }

        .modal-body {
            padding: 1.5rem;
        }

        .renovar-info, .detalle-info {
            text-align: center;
        }

        .renovar-info p, .detalle-info p {
            margin-bottom: 1rem;
            color: var(--gray-700);
        }

        .renovar-actions {
            display: flex;
            justify-content: center;
            gap: 1rem;
            margin-top: 1.5rem;
        }

        .btn-confirmar {
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
            border: none;
            padding: 0.625rem 1.5rem;
            border-radius: var(--radius-lg);
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
        }

        .btn-confirmar:hover {
            transform: translateY(-2px);
            filter: brightness(1.05);
        }

        .btn-cancelar {
            background: var(--gray-100);
            color: var(--gray-700);
            border: none;
            padding: 0.625rem 1.5rem;
            border-radius: var(--radius-lg);
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
        }

        .btn-cancelar:hover {
            background: var(--gray-200);
        }

        /* ========== TOAST ========== */
        .toast-modern {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            padding: 0.75rem 1.25rem;
            background: var(--gray-900);
            color: white;
            border-radius: var(--radius-lg);
            font-size: 0.875rem;
            opacity: 0;
            transform: translateY(20px);
            transition: all 0.3s ease;
            pointer-events: none;
            z-index: 1100;
        }

        .toast-modern.show {
            opacity: 1;
            transform: translateY(0);
        }

        .toast-modern.error {
            background: linear-gradient(135deg, #dc2626, #b91c1c);
        }

        /* ========== TEMA OSCURO ========== */
        body.dark-theme .prestamos-card {
            background: #1e293b;
            border-color: rgba(255, 255, 255, 0.1);
        }

        body.dark-theme .prestamos-header {
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.15), rgba(167, 139, 250, 0.08));
            border-bottom-color: rgba(255, 255, 255, 0.1);
        }

        body.dark-theme .btn-back {
            background: #334155;
            color: #e2e8f0;
        }

        body.dark-theme .btn-back:hover {
            background: #475569;
        }

        body.dark-theme .user-badge {
            background: #334155;
            color: #e2e8f0;
        }

        body.dark-theme .tabs-container {
            background: #1e293b;
            border-bottom-color: #334155;
        }

        body.dark-theme .tab-btn {
            color: #94a3b8;
        }

        body.dark-theme .tab-btn:hover {
            color: #c4b5fd;
            background: #334155;
        }

        body.dark-theme .tab-btn.active {
            color: #c4b5fd;
            background: #334155;
        }

        body.dark-theme .prestamos-table th,
        body.dark-theme .sanciones-table th {
            background: #0f172a;
            color: #94a3b8;
            border-bottom-color: #334155;
        }

        body.dark-theme .prestamos-table td,
        body.dark-theme .sanciones-table td {
            color: #e2e8f0;
            border-bottom-color: #334155;
        }

        body.dark-theme .prestamos-table tr:hover td,
        body.dark-theme .sanciones-table tr:hover td {
            background: #0f172a;
        }

        body.dark-theme .libro-info strong {
            color: #f1f5f9;
        }

        body.dark-theme .btn-detalle {
            background: #334155;
            color: #e2e8f0;
        }

        body.dark-theme .btn-detalle:hover {
            background: #475569;
        }

        body.dark-theme .modal-content {
            background: #1e293b;
        }

        body.dark-theme .modal-header {
            border-bottom-color: #334155;
        }

        body.dark-theme .modal-header h3 {
            color: #f1f5f9;
        }

        body.dark-theme .renovar-info p,
        body.dark-theme .detalle-info p {
            color: #e2e8f0;
        }

        body.dark-theme .btn-cancelar {
            background: #334155;
            color: #e2e8f0;
        }

        body.dark-theme .btn-cancelar:hover {
            background: #475569;
        }

        /* ========== RESPONSIVE ========== */
        @@media (max-width: 768px) {
            body {
                padding: 1rem;
            }
            
            .prestamos-header {
                flex-direction: column;
                gap: 1rem;
                padding: 1rem;
            }
            
            .header-left {
                flex-wrap: wrap;
                justify-content: center;
            }
            
            .tabs-container {
                flex-wrap: wrap;
                padding: 0.5rem 1rem 0 1rem;
            }
            
            .tab-btn {
                flex: 1;
                justify-content: center;
                padding: 0.5rem;
                font-size: 0.75rem;
            }
            
            .tab-content {
                padding: 1rem;
            }
            
            .prestamos-table th,
            .prestamos-table td,
            .sanciones-table th,
            .sanciones-table td {
                padding: 0.75rem;
                font-size: 0.75rem;
            }
            
            .btn-renovar, .btn-detalle {
                padding: 0.25rem 0.5rem;
                font-size: 0.7rem;
            }
            
            .toast-modern {
                bottom: 1rem;
                right: 1rem;
                left: 1rem;
                text-align: center;
            }
        }
    </style>
}

<div class="prestamos-container">
    <div class="prestamos-card">
        <!-- HEADER -->
        <div class="prestamos-header">
            <div class="header-left">
                <a href="/Ventanas/Cliente" class="btn-back">
                    <i class="bi bi-arrow-left"></i>
                    Volver
                </a>
                <h1 class="title">
                    <i class="bi bi-journal-bookmark-fill"></i>
                    Mis Préstamos
                </h1>
            </div>
            <div class="header-right">
                <span class="user-badge">
                    <i class="bi bi-person-circle"></i>
                    @Model.UsuarioNombre
                </span>
            </div>
        </div>

        <!-- TABS -->
        <div class="tabs-container">
            <button class="tab-btn active" data-tab="activos">
                <i class="bi bi-clock-history"></i>
                Préstamos Activos
                <span class="tab-count" id="activosCount">0</span>
            </button>
            <button class="tab-btn" data-tab="historial">
                <i class="bi bi-archive"></i>
                Historial
                <span class="tab-count" id="historialCount">0</span>
            </button>
            <button class="tab-btn" data-tab="sanciones">
                <i class="bi bi-exclamation-triangle"></i>
                Sanciones
                <span class="tab-count" id="sancionesCount">0</span>
            </button>
        </div>

        <!-- TAB PRÉSTAMOS ACTIVOS -->
        <div id="tabActivos" class="tab-content active">
            <div class="table-wrapper">
                <table class="prestamos-table">
                    <thead>
                        <tr>
                            <th>Libro</th>
                            <th>Fecha Préstamo</th>
                            <th>Fecha Devolución</th>
                            <th>Días Restantes</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </thead>
                    <tbody id="activosBody">
                        <tr><td colspan="6" class="text-center">Cargando...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- TAB HISTORIAL -->
        <div id="tabHistorial" class="tab-content">
            <div class="table-wrapper">
                <table class="prestamos-table">
                    <thead>
                        <tr>
                            <th>Libro</th>
                            <th>Fecha Préstamo</th>
                            <th>Fecha Devolución Real</th>
                            <th>Estado</th>
                        </thead>
                    <tbody id="historialBody">
                        <tr><td colspan="4" class="text-center">Cargando...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- TAB SANCIONES -->
        <div id="tabSanciones" class="tab-content">
            <div class="table-wrapper">
                <table class="sanciones-table">
                    <thead>
                        <tr>
                            <th>Descripción</th>
                            <th>Fecha Inicio</th>
                            <th>Fecha Fin</th>
                            <th>Estado</th>
                        </thead>
                    <tbody id="sancionesBody">
                        <tr><td colspan="4" class="text-center">Cargando...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- MODAL RENOVAR PRÉSTAMO -->
<div id="modalRenovar" class="modal-modern" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="bi bi-arrow-repeat"></i> Renovar Préstamo</h3>
            <button class="modal-close" onclick="closeModal()">&times;</button>
        </div>
        <div class="modal-body" id="modalRenovarBody"></div>
    </div>
</div>

<!-- TOAST -->
<div id="toast" class="toast-modern"></div>

@section Scripts {
    <script>
        (function() {
            let prestamosActivos = [];
            let prestamosHistorial = [];
            let sanciones = [];

            function getAntiForgeryToken() {
                const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
                return tokenInput ? tokenInput.value : '';
            }

            function showToast(message, isError) {
                const toast = document.getElementById('toast');
                toast.textContent = message;
                toast.className = 'toast-modern show' + (isError ? ' error' : '');
                setTimeout(function() { toast.className = 'toast-modern'; }, 3000);
            }

            async function cargarDatos() {
                const token = getAntiForgeryToken();
                try {
                    const resp = await fetch('?handler=DatosPrestamosAjax', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        }
                    });
                    if (!resp.ok) throw new Error('Error al cargar datos');
                    const data = await resp.json();
                    
                    prestamosActivos = data.prestamosActivos || [];
                    prestamosHistorial = data.prestamosHistorial || [];
                    sanciones = data.sanciones || [];
                    
                    actualizarContadores();
                    renderizarActivos();
                    renderizarHistorial();
                    renderizarSanciones();
                } catch (err) {
                    console.error(err);
                    showToast('Error al cargar los datos', true);
                }
            }

            function actualizarContadores() {
                const activosCount = document.getElementById('activosCount');
                const historialCount = document.getElementById('historialCount');
                const sancionesCount = document.getElementById('sancionesCount');
                
                if (activosCount) activosCount.textContent = prestamosActivos.length;
                if (historialCount) historialCount.textContent = prestamosHistorial.length;
                
                var sancionesActivas = sanciones.filter(function(s) { 
                    return !s.fechaFin || new Date(s.fechaFin) > new Date(); 
                });
                if (sancionesCount) sancionesCount.textContent = sancionesActivas.length;
            }

            function calcularDiasRestantes(fechaDevolucion) {
                var hoy = new Date();
                var devolucion = new Date(fechaDevolucion);
                var diffTime = devolucion - hoy;
                var diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                return diffDays;
            }

            function obtenerEstadoDias(dias) {
                if (dias < 0) return { text: 'VENCIDO', class: 'estado-vencido' };
                if (dias <= 3) return { text: 'PRÓXIMO A VENCER', class: 'estado-proximo' };
                return { text: 'ACTIVO', class: 'estado-activo' };
            }

            function escapeHtml(text) {
                if (!text) return '';
                var div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }

            function formatearFecha(fechaStr) {
                if (!fechaStr) return 'N/A';
                var fecha = new Date(fechaStr);
                return fecha.toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric' });
            }

            function renderizarActivos() {
                var tbody = document.getElementById('activosBody');
                if (!tbody) return;
                
                if (prestamosActivos.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="6" class="text-center">📭 No tienes préstamos activos</td></tr>';
                    return;
                }
                
                var html = '';
                for (var i = 0; i < prestamosActivos.length; i++) {
                    var p = prestamosActivos[i];
                    var dias = calcularDiasRestantes(p.fechaDevolucion);
                    var estado = obtenerEstadoDias(dias);
                    var puedeRenovar = dias > 0 && !p.renovado;
                    
                    html += '<tr>' +
                        '<td><div class="libro-info"><strong>' + escapeHtml(p.libroTitulo) + '</strong><small>ISBN: ' + (p.isbn || 'N/A') + '</small></div></td>' +
                        '<td>' + formatearFecha(p.fechaPrestamo) + '</td>' +
                        '<td>' + formatearFecha(p.fechaDevolucion) + '</td>' +
                        '<td class="' + estado.class + '">' + (dias > 0 ? dias + ' días' : Math.abs(dias) + ' días tarde') + '</td>' +
                        '<td><span class="estado-badge ' + estado.class + '">' + estado.text + '</span></td>' +
                        '<td>' +
                        (puedeRenovar ? '<button class="btn-renovar" data-id="' + p.id + '" data-titulo="' + escapeHtml(p.libroTitulo) + '"><i class="bi bi-arrow-repeat"></i> Renovar</button>' : '') +
                        '<button class="btn-detalle" data-id="' + p.id + '" data-titulo="' + escapeHtml(p.libroTitulo) + '" data-fecha="' + formatearFecha(p.fechaPrestamo) + '" data-devolucion="' + formatearFecha(p.fechaDevolucion) + '"><i class="bi bi-eye"></i> Detalle</button>' +
                        '</td>' +
                        '</tr>';
                }
                tbody.innerHTML = html;
                
                document.querySelectorAll('.btn-renovar').forEach(function(btn) {
                    btn.addEventListener('click', function() { mostrarModalRenovar(this.dataset.id, this.dataset.titulo); });
                });
                
                document.querySelectorAll('.btn-detalle').forEach(function(btn) {
                    btn.addEventListener('click', function() { mostrarDetallePrestamo(this.dataset); });
                });
            }

            function renderizarHistorial() {
                var tbody = document.getElementById('historialBody');
                if (!tbody) return;
                
                if (prestamosHistorial.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="4" class="text-center">📋 No hay préstamos en el historial</td></tr>';
                    return;
                }
                
                var html = '';
                for (var i = 0; i < prestamosHistorial.length; i++) {
                    var p = prestamosHistorial[i];
                    var estuvoVencido = p.fechaEntregaReal && new Date(p.fechaEntregaReal) > new Date(p.fechaDevolucion);
                    
                    html += '<tr>' +
                        '<td><div class="libro-info"><strong>' + escapeHtml(p.libroTitulo) + '</strong><small>ISBN: ' + (p.isbn || 'N/A') + '</small></div></td>' +
                        '<td>' + formatearFecha(p.fechaPrestamo) + '</td>' +
                        '<td>' + formatearFecha(p.fechaEntregaReal || p.fechaDevolucion) + '</td>' +
                        '<td><span class="estado-badge ' + (estuvoVencido ? 'estado-vencido' : 'estado-completado') + '">' + (estuvoVencido ? 'Devuelto tarde' : 'Completado') + '</span></td>' +
                        '</tr>';
                }
                tbody.innerHTML = html;
            }

            function renderizarSanciones() {
                var tbody = document.getElementById('sancionesBody');
                if (!tbody) return;
                
                if (sanciones.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="4" class="text-center">✅ No tienes sanciones</td></tr>';
                    return;
                }
                
                var html = '';
                var hoy = new Date();
                for (var i = 0; i < sanciones.length; i++) {
                    var s = sanciones[i];
                    var fechaFin = s.fechaFin ? new Date(s.fechaFin) : null;
                    var activa = !fechaFin || fechaFin > hoy;
                    
                    html += '<tr>' +
                        '<td>' + escapeHtml(s.descripcion) + '</td>' +
                        '<td>' + formatearFecha(s.fechaInicio) + '</td>' +
                        '<td>' + (s.fechaFin ? formatearFecha(s.fechaFin) : 'Indefinida') + '</td>' +
                        '<td><span class="estado-badge ' + (activa ? 'estado-vencido' : 'estado-completado') + '">' + (activa ? 'Activa' : 'Finalizada') + '</span></td>' +
                        '</tr>';
                }
                tbody.innerHTML = html;
            }

            async function mostrarModalRenovar(id, titulo) {
                var modal = document.getElementById('modalRenovar');
                var modalBody = document.getElementById('modalRenovarBody');
                
                modalBody.innerHTML = `
                    <div class="renovar-info">
                        <p><strong>📖 Libro:</strong> ${titulo}</p>
                        <p>¿Deseas renovar este préstamo por 7 días más?</p>
                        <div class="renovar-actions">
                            <button class="btn-cancelar" onclick="closeModal()">Cancelar</button>
                            <button class="btn-confirmar" id="confirmarRenovar" data-id="${id}">Renovar</button>
                        </div>
                    </div>
                `;
                
                modal.style.display = 'flex';
                
                document.getElementById('confirmarRenovar')?.addEventListener('click', async function() {
                    var token = getAntiForgeryToken();
                    try {
                        var resp = await fetch('?handler=RenovarPrestamoAjax', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': token
                            },
                            body: JSON.stringify({ prestamoId: parseInt(id) })
                        });
                        var data = await resp.json();
                        if (data.success) {
                            showToast('✅ Préstamo renovado exitosamente', false);
                            closeModal();
                            cargarDatos();
                        } else {
                            showToast(data.message || 'Error al renovar', true);
                        }
                    } catch (err) {
                        showToast('Error de conexión', true);
                    }
                });
            }

            function mostrarDetallePrestamo(data) {
                var modal = document.getElementById('modalRenovar');
                var modalBody = document.getElementById('modalRenovarBody');
                
                modalBody.innerHTML = `
                    <div class="detalle-info">
                        <p><strong>📖 Libro:</strong> ${data.titulo}</p>
                        <p><strong>📅 Fecha Préstamo:</strong> ${data.fecha}</p>
                        <p><strong>⏰ Fecha Devolución:</strong> ${data.devolucion}</p>
                        <div class="renovar-actions">
                            <button class="btn-cancelar" onclick="closeModal()">Cerrar</button>
                        </div>
                    </div>
                `;
                
                modal.style.display = 'flex';
            }

            window.closeModal = function() {
                document.getElementById('modalRenovar').style.display = 'none';
            };
            
            // TABS
            document.querySelectorAll('.tab-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var tab = this.dataset.tab;
                    document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
                    document.querySelectorAll('.tab-content').forEach(function(c) { c.classList.remove('active'); });
                    this.classList.add('active');
                    document.getElementById('tab' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
                });
            });
            
            cargarDatos();
        })();
    </script>
}